# ─────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────
DB_HOST=localhost
# PostgreSQL server hostname or IP address
DB_PORT=5432
# PostgreSQL server port number
DB_NAME=tallersoft
# Name of the application database
DB_USER=postgres
# Main database user for application (write access)
DB_PASSWORD=tu_password_seguro
# Main database user password (change in production)

# ─────────────────────────────────────────────────────────────────────
# JWT SECURITY
# ─────────────────────────────────────────────────────────────────────
JWT_SECRET=clave_secreta_minimo_256_bits_para_produccion_cambiar_esto
# Secret key for JWT signing (minimum 256 bits / 32 characters). Use random string in production.
JWT_EXPIRATION_MS=86400000
# JWT token expiration time in milliseconds (86400000 = 24 hours)

# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC CLAUDE API (AI Assistant)
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API key for Anthropic Claude (get from https://console.anthropic.com)
CLAUDE_MODEL=claude-sonnet-4-20250514
# Claude model version to use for the AI assistant
CLAUDE_MAX_TOKENS=1000
# Maximum tokens per response from Claude API

# ─────────────────────────────────────────────────────────────────────
# MERCADOPAGO INTEGRATION (Payment Gateway)
# ─────────────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MercadoPago access token for API calls (get from MercadoPago dashboard)
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MercadoPago public key for frontend integration
MP_WEBHOOK_SECRET=tu_webhook_secret_para_validar_firmas
# Secret key to validate MercadoPago webhook signatures (HMAC-SHA256)

# ─────────────────────────────────────────────────────────────────────
# SERVICE PORTS
# ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
# API Gateway port (public entry point for all client requests)
BACKEND_PORT=8081
# Core Service (Spring Boot backend) port
ANALYTICS_PORT=8082
# Analytics Service (Python/FastAPI) port
FRONTEND_PORT=4200
# Frontend Angular development server port (or 80 for production with nginx)
